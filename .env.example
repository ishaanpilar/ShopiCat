# Google Gemini API key — used server-side only by /api/enhance to polish
# product descriptions and write the cover tagline. Get a free key at
# https://aistudio.google.com/apikey
#
# The app works WITHOUT this (it falls back to the store's own descriptions);
# set it to enable the AI polish step.
GEMINI_API_KEY=

# Optional — override the Gemini model. Defaults to gemini-flash-lite-latest
# (fast, cheap, always the current lite model). gemini-flash-latest is higher
# quality but slower and more often rate-limited on the free tier.
# GEMINI_MODEL=gemini-flash-lite-latest
